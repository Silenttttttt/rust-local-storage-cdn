# For docker-compose.standalone.yml (backend + external DB)
POSTGRES_HOST=my-db.example.com
POSTGRES_PORT=5432
POSTGRES_DB=local_storage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# For docker-compose.yml (Docker Postgres)
# POSTGRES_* defaults work with --profile db

# Backend
PORT=8080
LOG_LEVEL=INFO
MAX_FILE_SIZE=1073741824
STORAGE_PATH=/storage

# Redis (when using --profile redis + docker-compose.redis.yml)
ENABLE_REDIS=false

# Frontend (when using --profile frontend)
API_URL=http://localhost:8080
